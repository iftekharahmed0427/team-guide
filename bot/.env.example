# Postgres connection (the SAME Supabase database the website uses). This is the
# ONLY thing the bot needs in its environment — the Discord token and all other
# config are set in the website under Settings → Discord bot, and the bot reads
# them from the database. Use the pooled connection string.
DATABASE_URL=
# Leave empty for Supabase (TLS stays on). Set to "disable" only for a local
# non-TLS Postgres.
DATABASE_SSL=
