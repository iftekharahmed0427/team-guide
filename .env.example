# Public URL of the app. Used by Better Auth for OAuth callbacks and redirects.
BETTER_AUTH_URL=http://localhost:3000

# Session signing secret. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# --- Supabase Postgres ---
# App runtime: Supabase Transaction pooler (port 6543).
#   postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=
# Migrations / long-lived servers: Supabase Direct connection (port 5432).
#   postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=
# Leave empty for Supabase (TLS stays on). Set to "disable" only for a local non-TLS Postgres.
DATABASE_SSL=

# Discord OAuth app: https://discord.com/developers/applications -> your app -> OAuth2
# Add this redirect URL there: http://localhost:3000/api/auth/callback/discord
# (and the production equivalent for your domain).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Bootstrap admins: emails always allowed to sign in AND granted the admin role.
# Use this to seed the first admin(s); everyone else is invited from the dashboard.
# Comma-separated.
AUTH_BOOTSTRAP_ADMINS=
